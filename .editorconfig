# Top-most EditorConfig file
root = true

# Default settings for all files
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# Markdown files
[*.md]
trim_trailing_whitespace = false

# Python files
[*.py]
indent_size = 4

# JavaScript and TypeScript files
[*.{js,ts,jsx,tsx}]
indent_size = 2

# JSON files
[*.json]
indent_size = 2

# YAML files
[*.{yml,yaml}]
indent_size = 2

# HTML files
[*.html]
indent_size = 2

# CSS, SCSS, and LESS files
[*.{css,scss,less}]
indent_size = 2

# Shell scripts
[*.sh]
indent_size = 2

# Makefile
[Makefile]
indent_style = tab

# Go files
[*.go]
indent_style = tab
indent_size = 4

# Rust files
[*.rs]
indent_size = 4

# Java files
[*.java]
indent_size = 4

# C and C++ files
[*.{c,cpp,h,hpp}]
indent_size = 4

# XML files
[*.xml]
indent_size = 2

# Batch files
[*.bat]
end_of_line = crlf

# Config files
[*.{ini,conf}]
indent_size = 4
